<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.springboot.mapper.LocationMapper">
    <insert id="save">
        insert into location(floor, area, admin)
        values(#{floor}, #{area}, #{admin})
    </insert>
    <update id="update">
        update location set floor = #{floor}, area = #{area}, admin = #{admin}, updatetime = #{updatetime} where id = #{id}
    </update>
    <delete id="deleteById">
        delete from location where id = #{id}
    </delete>
    <select id="getById" resultType="com.example.springboot.entity.Location">
        select * from location where id = #{id}
    </select>
    <select id="list" resultType="com.example.springboot.entity.Location">
        select * from location
    </select>
    <select id="listByCondition" resultType="com.example.springboot.entity.Location">
        select * from location
        <where>
            <if test="floor != null and floor != ''">
                floor like concat('%', #{ floor },'%')
            </if>
            <if test="admin != null and admin != ''">
                admin like concat('%', #{ admin },'%')
            </if>
        </where>
        order by id desc
    </select>

</mapper>