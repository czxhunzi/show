<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.springboot.mapper.NoteMapper">
    <insert id="save">
        insert into note(book_no, user_id, message)
        values(#{bookNo}, #{userId}, #{message})
    </insert>
    <update id="update">
        update  note set book_no = #{bookNo}, user_id = #{userId}, updatetime = #{updatetime} where id = #{id}
    </update>
    <delete id="deleteById">
        delete from note where id = #{id}
    </delete>
    <select id="getById" resultType="com.example.springboot.entity.Note">
        select * from note where id = #{id}
    </select>
    <select id="list" resultType="com.example.springboot.entity.Note">
        select * from note
    </select>
    <select id="listByCondition" resultType="com.example.springboot.entity.Note">
        select * from note
        <where>
            <if test="bookNo != null and bookNo != ''">
                and book_no like concat('%', #{ bookNo },'%')
            </if>
            <if test="userId != null and userId != ''">
                and user_name like concat('%', #{ userName },'%')
            </if>
        </where>
        order by id desc
    </select>
</mapper>