<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.springboot.mapper.PublishMapper">
    <insert id="save">
        insert into publish(name)
        values(#{name})
    </insert>
    <update id="update">
        update  publish set name = #{name}, updatetime = #{updatetime} where id = #{id}
    </update>
    <delete id="deleteById">
        delete from publish where id = #{id}
    </delete>
    <select id="getById" resultType="com.example.springboot.entity.Publish">
        select * from publish where id = #{id}
    </select>
    <select id="list" resultType="com.example.springboot.entity.Publish">
        select * from publish
    </select>
    <select id="listByCondition" resultType="com.example.springboot.entity.Publish">
        select * from publish
        <where>
            <if test="name != null and name != ''">
                name like concat('%', #{ name },'%')
            </if>
        </where>
        order by id desc
    </select>

</mapper>